{
  "name": "rugby-skycatch",
  "version": "1.0.0",
  "description": "Jeu 2D d'attrape-ballons de rugby avec pipeline DevOps complet",
  "main": "src/game.js",
  "scripts": {
    "test": "jest --coverage",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "start": "python3 -m http.server 8080 || npx serve ."
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "src/**/*.js"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 80,
        "functions": 80
      }
    }
  },
  "keywords": ["rugby", "game", "devops", "docker"],
  "license": "MIT"
}
